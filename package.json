{
  "name": "juniper-iiif",
  "version": "1.2.2",
  "description": "High-performance IIIF viewer with WebGPU/WebGL rendering, annotations, and comparison mode",
  "author": "Anzhu <anzhul@umich.edu>",
  "license": "MIT",
  "keywords": [
    "iiif",
    "webgpu",
    "webgl",
    "image-viewer",
    "annotations",
    "digital-humanities"
  ],
  "type": "module",
  "main": "./dist/iiif-viewer.umd.cjs",
  "module": "./dist/iiif-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/iiif-viewer.js",
      "require": "./dist/iiif-viewer.umd.cjs"
    },
    "./style.css": "./dist/iiif-viewer.css",
    "./theme.css": "./dist/iiif-theme.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@webgpu/types": "^0.1.65",
    "sass-embedded": "^1.92.1",
    "typescript": "~5.8.3",
    "vite": "^7.1.2"
  },
  "dependencies": {
    "gl-matrix": "^3.4.4"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": "^0.10.32"
  },
  "peerDependenciesMeta": {
    "@mediapipe/tasks-vision": {
      "optional": true
    }
  }
}
